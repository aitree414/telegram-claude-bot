# =============================================================================
# Telegram Claude Bot - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# =============================================================================
# Telegram Configuration
# =============================================================================
# Get from https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram user/group IDs allowed to interact with the bot
# Comma-separated list of numeric user IDs
ALLOWED_USER_IDS=123456789,987654321

# =============================================================================
# Network Mode
# =============================================================================
# Set to "testnet" to use Sepolia testnet instead of mainnet.
# When testnet mode is active:
#   - DEX addresses are overridden with Sepolia Uniswap V2 addresses
#   - Trading limits are lowered for safety
#   - Sepolia chain ID (11155111) is used
# NETWORK_MODE=mainnet

# =============================================================================
# Mainnet RPC URLs (used when NETWORK_MODE=mainnet)
# =============================================================================
# Get free endpoints from https://alchemy.com or https://infura.io
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_key_here
BSC_RPC_URL=https://bsc-dataseed.binance.org/
ARB_RPC_URL=https://arb1.arbitrum.io/rpc
POLYGON_RPC_URL=https://polygon-rpc.com
AVAX_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# =============================================================================
# Testnet RPC URLs (used when NETWORK_MODE=testnet)
# =============================================================================
# Get Sepolia RPC from https://alchemy.com (free tier works)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_key_here

# =============================================================================
# Wallet Configuration
# =============================================================================
# NEVER use a mainnet wallet private key! Use a dedicated test wallet.
# Private key (hex string with 0x prefix)
PRIVATE_KEY=0xyour_private_key_here

# Alternatively, use an encrypted private key (safer)
# ENCRYPTED_PRIVATE_KEY=your_encrypted_key
# ENCRYPTED_PRIVATE_KEY_PASSWORD=your_password

# Wallet address (leave empty to derive from private key)
# WALLET_ADDRESS=0x...

# =============================================================================
# Gas & Transaction Configuration
# =============================================================================
GAS_MULTIPLIER=1.1
MAX_GAS_PRICE_GWEI=150
MAX_SLIPPAGE=0.05  # 5%
TRANSACTION_TIMEOUT=300  # seconds

# =============================================================================
# Risk Management & Trading Limits
# =============================================================================
MAX_TRADE_ETH=0.1
MIN_TRADE_ETH=0.001
MAX_POSITION_ETH=1.0
DEFAULT_SLIPPAGE_BPS=500  # 5% in basis points

# =============================================================================
# Testnet-specific Trading Limits (used when NETWORK_MODE=testnet)
# =============================================================================
# These override MAX/MIN_TRADE_ETH when in testnet mode
# TEST_MAX_TRADE_ETH=0.01
# TEST_MIN_TRADE_ETH=0.0001

# =============================================================================
# Testnet DEX Address Overrides (used when NETWORK_MODE=testnet)
# =============================================================================
# Sepolia Uniswap V2 addresses (defaults shown below)
# TEST_UNISWAP_V2_ROUTER=0xC532a74256D338Db9Ee4E7e38E9046eE5fE6a8a3
# TEST_UNISWAP_V2_FACTORY=0x7E0987E8b5C0E2D1F2B0c7D5F8F1E3A1B5C8D9E0

# =============================================================================
# Monitoring Configuration
# =============================================================================
MONITOR_INTERVAL=30  # seconds
MAX_BLOCKS_TO_SCAN=1000
CONFIRMATION_BLOCKS=3

# Event monitoring thresholds
MIN_LIQUIDITY_ETH=10.0
MIN_HOLDER_COUNT=100
LARGE_TRANSFER_THRESHOLD_ETH=50.0
NEW_TOKEN_AGE_HOURS=24

# =============================================================================
# Risk Limits
# =============================================================================
MAX_DAILY_TRADES=10
MAX_DAILY_LOSS_ETH=0.5
STOP_LOSS_PCT=0.10  # 10%
TAKE_PROFIT_PCT=0.30  # 30%
COOLDOWN_MINUTES=30

# =============================================================================
# DEX Configuration (Mainnet)
# =============================================================================
# Uniswap V2 (Ethereum)
# UNISWAP_V2_ROUTER=0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D
# UNISWAP_V2_FACTORY=0x5C69bEe701ef814a2B6a3EDD4B1652CB9cc5aA6f

# Uniswap V3 (Ethereum)
# UNISWAP_V3_ROUTER=0xE592427A0AEce92De3Edee1F18E0157C05861564
# UNISWAP_V3_FACTORY=0x1F98431c8aD98523631AE4a59f267346ea31F984

# =============================================================================
# Blacklist
# =============================================================================
BLACKLIST_PATH=data/blacklist.json

# =============================================================================
# Caching
# =============================================================================
CACHE_TTL_BLOCKS=100
CACHE_TTL_TRANSACTIONS=3600  # 1 hour

# =============================================================================
# Token Deployment (used by scripts/deploy_token.py and deploy_and_verify.py)
# =============================================================================
# TEST_TOKEN_NAME=ClaudeBot Test Token
# TEST_TOKEN_SYMBOL=CTST
# TEST_TOKEN_DECIMALS=18

# Optional: auto-mint additional tokens after deployment
# MINT_AMOUNT=1000000000000000000000  # 1000 tokens (18 decimals)

# =============================================================================
# Debug & Logging
# =============================================================================
DEBUG_MODE=false
LOG_ALL_TRANSACTIONS=false
